# Скопируйте этот файл в .env и подставьте свои значения.
# Для локального запуска можно вообще не создавать .env — по умолчанию
# используется локальный SQLite и дефолтные (небезопасные) секреты.

ENVIRONMENT=development
DEBUG=true

# --- База данных ---
# Локально (по умолчанию): SQLite, ничего настраивать не нужно.
# DATABASE_URL=sqlite+aiosqlite:///./dev.db
#
# Продакшн (Supabase Postgres). Возьмите connection string в
# Supabase -> Project Settings -> Database -> Connection string -> URI,
# и замените префикс postgresql:// на postgresql+asyncpg://
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# DATABASE_SSL=true
# DATABASE_DISABLE_STATEMENT_CACHE=true
# AUTO_CREATE_TABLES=false

# --- JWT (обязательно смените в проде на длинную случайную строку) ---
JWT_SECRET_KEY=change-me-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Сессия админ-панели (тоже смените в проде) ---
ADMIN_SESSION_SECRET=change-me-admin-secret

# --- CORS: домен(ы) фронтенда через запятую ---
# CORS_ORIGINS=https://your-username.github.io,http://localhost:5500
CORS_ORIGINS=*

# --- Загрузка файлов ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
MAX_IMAGES_PER_AD=6
